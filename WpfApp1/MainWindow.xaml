<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#E9EDF2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#17202A">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Shell" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B9C4D0"
                               Text="Application frame" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Height="44"
                            Margin="0,0,0,12"
                            Background="#F4B942"
                            BorderThickness="0"
                            Command="{Binding NavigateDashboardCommand}"
                            Content="Dashboard"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24" Background="White" CornerRadius="16">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock FontSize="28"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentPageTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#666666"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Padding="14,8"
                            Background="#EEF3F7"
                            CornerRadius="10">
                        <TextBlock Text="{Binding GlobalConnectionSummary}" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="16">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>
