<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#09121F">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0F1B2D" />
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#22344B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#33C7A5" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F4F7FB" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#16263A" />
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="BorderBrush" Value="#2A425F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="#09121F">
        <Border Margin="18"
                Background="#EAF0F6"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBrush}"
                        CornerRadius="24,0,0,24">
                    <Grid Margin="26">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="26" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Border Width="54"
                                    Height="54"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="18">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#0F1B2D"
                                           Text="SF" />
                            </Border>
                            <TextBlock Margin="0,18,0,0"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="Smart Factory" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#8FA5BD"
                                       Text="Operator control shell" />
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Margin="0,0,0,12"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#6D839C"
                                       Text="NAVIGATION" />
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Background="{StaticResource AccentBrush}"
                                    BorderThickness="0"
                                    Command="{Binding NavigateDashboardCommand}"
                                    Content="Dashboard"
                                    Foreground="#0F1B2D" />
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Content="Inspection History"
                                    IsEnabled="False" />
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Content="Alarm Log"
                                    IsEnabled="False" />
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Content="Manual Control"
                                    IsEnabled="False" />
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Content="Settings"
                                    IsEnabled="False" />
                        </StackPanel>

                        <Border Grid.Row="4"
                                Padding="18"
                                Background="#132338"
                                BorderBrush="{StaticResource SidebarBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Foreground="#7E96B0"
                                           Text="System Status" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="Online" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#AFC0D2"
                                           Text="{Binding GlobalConnectionSummary}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="26"
                            Background="White"
                            CornerRadius="22">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#4C647D"
                                           Text="BASELINE UI" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="#17263A"
                                           Text="{Binding CurrentPageTitle}" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#66788B"
                                           Text="{Binding StatusMessage}" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right"
                                        HorizontalAlignment="Right">
                                <Border Padding="14,8"
                                        HorizontalAlignment="Right"
                                        Background="#E9FFF8"
                                        CornerRadius="12">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#148B71"
                                               Text="{Binding GlobalConnectionSummary}" />
                                </Border>
                                <TextBlock Margin="0,12,0,0"
                                           HorizontalAlignment="Right"
                                           Foreground="#7D8FA1"
                                           Text="Factory Dashboard" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="22">
                        <ContentControl Content="{Binding CurrentViewModel}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
